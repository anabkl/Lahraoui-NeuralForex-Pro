# Lahraoui-NeuralForex-Pro local configuration
# Copy to .env only when you want to override the safe defaults.

# Host ports. Change these if another app already uses the default port.
POSTGRES_HOST_PORT=5432
BRAIN_HOST_PORT=8000
EXECUTOR_HOST_PORT=8080
MONITOR_HOST_PORT=3000

# PostgreSQL
POSTGRES_DB=neuralforex
POSTGRES_USER=neuralforex
POSTGRES_PASSWORD=change_me_for_local_use

# Brain service
BRAIN_PORT=8000
SYMBOL=EURUSD
MODEL_WEIGHTS_PATH=/app/weights/model.weights.h5

# Market data
# demo: deterministic synthetic data, no internet/API key required.
# twelvedata: live data, requires TWELVE_DATA_API_KEY.
MARKET_DATA_MODE=demo
TWELVE_DATA_API_KEY=
TWELVE_DATA_SYMBOL=EUR/USD

# Sentiment
# demo: neutral fast response, no internet/model download required.
# live: fetch FED/ECB RSS feeds and use the keyword/optional FinBERT pipeline.
SENTIMENT_MODE=demo

# Executor and risk controls
EXECUTION_MODE=SIMULATION
ACCOUNT_BALANCE=10000
RISK_PERCENT=1.0
STOP_LOSS_PIPS=20
TAKE_PROFIT_PIPS=40
REWARD_RATIO=2.0
MIN_CONFIDENCE=0.60

# Backtest
BACKTEST_DATA_FILE=/app/data/eur_usd_1min_7days15-04_to_21-4.csv
BACKTEST_SYNTHETIC_BARS=10000
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
